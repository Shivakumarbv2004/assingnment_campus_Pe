      "source": [
        "#QUESTION NO 11: \n",
        "\n",
        "\n",
        "# NUMBER PATTERN PRINTER PROGRAM\n",
        "\n",
        "\n",
        "# Step 1: Take height input\n",
        "height = int(input(\"Enter height of pattern: \"))\n",
        "\n",
        "# Step 2: Print pattern (Pattern 1 example)\n",
        "for i in range(1, height + 1):\n",
        "    for j in range(1, i + 1):\n",
        "        print(j, end=\" \")\n",
        "    print()"
