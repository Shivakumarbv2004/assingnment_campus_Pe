      "source": [
        "# QUESTION NO 12:\n",
        "\n",
        "\n",
        "# MULTIPLICATION TABLE PROGRAM\n",
        "\n",
        "\n",
        "# Step 1: Take inputs\n",
        "number = int(input(\"Enter number: \"))\n",
        "end_range = int(input(\"Enter range (end): \"))\n",
        "\n",
        "# Step 2: Generate multiplication table\n",
        "for i in range(1, end_range + 1):\n",
        "    print(f\"{number} x {i} = {number * i}\")"
      ]
